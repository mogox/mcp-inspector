<div class="space-y-4">
  <div class="border-b border-gray-200 pb-2">
    <h3 class="text-md font-semibold text-gray-900">Server Information</h3>
  </div>

  <% if info["capabilities"] %>
    <div>
      <h4 class="text-sm font-medium text-gray-700 mb-2">Capabilities</h4>
      <div class="bg-gray-50 rounded-md p-4">
        <% if info["capabilities"]["tools"] %>
          <div class="mb-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              Tools Supported
            </span>
          </div>
        <% end %>
        <% if info["capabilities"]["resources"] %>
          <div class="mb-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              Resources Supported
            </span>
          </div>
        <% end %>
        <% if info["capabilities"]["prompts"] %>
          <div class="mb-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              Prompts Supported
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if info["server_info"] %>
    <div>
      <h4 class="text-sm font-medium text-gray-700 mb-2">Server Details</h4>
      <div class="bg-gray-50 rounded-md p-4">
        <dl class="grid grid-cols-1 gap-3 text-sm">
          <% info["server_info"].each do |key, value| %>
            <div>
              <dt class="font-medium text-gray-500"><%= key.to_s.titleize %></dt>
              <dd class="text-gray-900"><%= value %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>
  <% end %>

  <div>
    <h4 class="text-sm font-medium text-gray-700 mb-2">Raw Response</h4>
    <pre class="bg-gray-900 text-gray-100 rounded-md p-4 overflow-x-auto text-xs"><%= JSON.pretty_generate(info) %></pre>
  </div>
</div>
